---
interface Props {
  name: string;
  image: string;
  quantity: string;
  shopUrl: string;
}

const { name, image, quantity, shopUrl } = Astro.props;
---

<div class="product-card bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow h-full flex flex-col">
  <!-- Product Image -->
  <div class="aspect-square bg-gray-50 flex items-center justify-center p-6">
    <img
      src={image}
      alt={name}
      class="max-w-full object-contain"
      style="max-height: 220px;"
      loading="lazy"
      width="400"
      height="400"
    />
  </div>

  <!-- Product Info -->
  <div class="p-4 text-center flex flex-col flex-1">
    <h3 class="font-medium text-gray-900 mb-1 min-h-[3rem] flex items-center justify-center">
      {name}
    </h3>
    <p class="text-sm text-gray-600 mb-4">
      {quantity}
    </p>

    <!-- View Product Button -->
    <a
      href={shopUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-auto block w-full bg-[#2d6b4f] hover:bg-[#245840] text-white font-medium py-3 px-4 rounded transition-colors"
    >
      View product
    </a>
  </div>
</div>
