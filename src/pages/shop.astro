---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import products from "../data/products.json";

const headline = "Wellness Shop";

// Group products by category
const productsByCategory = products.reduce((acc, product) => {
  if (!acc[product.category]) {
    acc[product.category] = {
      name: product.category,
      description: product.categoryDescription,
      products: []
    };
  }
  acc[product.category].products.push(product);
  return acc;
}, {} as Record<string, { name: string; description: string; products: typeof products }>);

const categories = Object.values(productsByCategory);
---

<Layout title="Wellness Shop | Wellness Medical Center">
  <section class="max-w-6xl mx-auto px-4 mt-24 2xl:px-0">
    <div class="md:flex md:items-center md:gap-8">
      <div class="md:w-3/5">
        <h2 class="text-4xl text-[var(--color-primary)] font-medium mb-4 mt-8">
          {headline}
        </h2>
        <p class="text-2xl mb-8">
          Discover our curated selection of wellness products.
        </p>
      </div>
    </div>

    <div class="flex flex-col gap-12 w-full">
      {categories.map(category => (
        <div class="category-section">
          <div class="mb-6">
            <h3 class="text-xl font-semibold text-[var(--color-primary)] mb-1">
              {category.name}
            </h3>
            <p class="text-gray-600 text-sm">
              {category.description}
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            {category.products.map(product => (
              <ProductCard
                name={product.name}
                image={product.image}
                quantity={product.quantity}
                shopUrl={product.shopUrl}
              />
            ))}
          </div>
        </div>
      ))}

    <!-- FDA Disclaimer -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <p class="text-sm text-gray-500 text-center max-w-xl mx-auto">
        These statements have not been evaluated by the Food and Drug
        Administration. These products are not intended to diagnose, treat,
        cure, or prevent any disease.
      </p>
    </div>
  </section>
</Layout>
