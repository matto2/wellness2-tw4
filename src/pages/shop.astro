  <script is:inline>
    // Lazy load Fullscript product embeds for better performance
    document.addEventListener('DOMContentLoaded', () => {
      // Store original script data and remove scripts to prevent immediate loading
      const productCards = document.querySelectorAll('.product-card');
      const scriptData = new Map();

      productCards.forEach((card, index) => {
        const script = card.querySelector('script[data-fs]');
        if (script) {
          // Store script data
          scriptData.set(card, {
            src: script.getAttribute('src'),
            dataFs: script.getAttribute('data-fs'),
            dataOtIgnore: script.hasAttribute('data-ot-ignore')
          });
          // Remove the script to prevent loading
          script.remove();
        }
      });

      // Set up Intersection Observer
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const card = entry.target;
              const data = scriptData.get(card);

              if (data && !card.hasAttribute('data-loaded')) {
                // Mark as loaded
                card.setAttribute('data-loaded', 'true');

                // Create and inject the script
                const script = document.createElement('script');
                script.src = data.src;
                script.setAttribute('data-fs', data.dataFs);
                if (data.dataOtIgnore) {
                  script.setAttribute('data-ot-ignore', '');
                }
                card.appendChild(script);

                // Stop observing this card
                observer.unobserve(card);
              }
            }
          });
        },
        {
          rootMargin: '300px', // Start loading 300px before card enters viewport
          threshold: 0.01
        }
      );

      // Observe all product cards
      productCards.forEach((card) => {
        observer.observe(card);
      });
    });
  </script>
